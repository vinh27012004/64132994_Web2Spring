<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://java.sun.com/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://java.sun.com/xml/ns/javaee
         http://java.sun.com/xml/ns/javaee/web-app_2_5.xsd"
         version="2.5">
  <display-name>Archetype Created Web Application</display-name>
  
  <!-- Default Home Servlet -->
  <servlet>
    <servlet-name>HomeServlet</servlet-name>
    <servlet-class>BAITH1_1.HomeServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>HomeServlet</servlet-name>
    <url-pattern>/</url-pattern>
  </servlet-mapping>
  
  <!-- Bài 1.1 -->
  <servlet>
    <servlet-name>TestDoGet</servlet-name>
    <servlet-class>BAITH1_1.TestDoGet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>TestDoGet</servlet-name>
    <url-pattern>/BAITH1_1/testDoGet</url-pattern>
  </servlet-mapping>
  
  <!-- Bài 1.2 -->
  <servlet>
    <servlet-name>TestDoPost</servlet-name>
    <servlet-class>BAITH1_2.TestDoPost</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>TestDoPost</servlet-name>
    <url-pattern>/BAITH1_2/testDoPost</url-pattern>
  </servlet-mapping>
  
  <!-- Bài 1.3 -->
  <servlet>
    <servlet-name>AboutMe</servlet-name>
    <servlet-class>BAITH1_3.AboutMe</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AboutMe</servlet-name>
    <url-pattern>/BAITH1_3/AboutMe</url-pattern>
  </servlet-mapping>
  
  <!-- Bài 1.4 -->
  <servlet>
    <servlet-name>BMI</servlet-name>
    <servlet-class>BAITH1_4.BMI</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>BMI</servlet-name>
    <url-pattern>/BAITH1_4/BMI</url-pattern>
  </servlet-mapping>
  
  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>
</web-app>
